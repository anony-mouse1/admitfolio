# Copy this file to ".env" and fill in your key, then run:
#   node --env-file=.env server.js

# Your Resend API key — get one free at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Who the email is "from".
# - Easiest: leave the default sandbox sender below. Resend's sandbox only
#   delivers to the email address you signed up to Resend with.
# - To send to any .edu address, verify a domain in Resend and use it here,
#   e.g.  FROM_EMAIL=Admitfolio <onboarding@yourdomain.com>
FROM_EMAIL=Admitfolio <onboarding@resend.dev>

# Optional: change the port (defaults to 8000)
# PORT=8000

# Where review-notification emails are sent (your inbox).
# ADMIN_EMAIL=you@example.com

# Who can sign into the admin review console (/admin). Admin access is proven by
# verifying one of these emails with a 6-digit code — no shared password.
# Comma-separated for multiple admins. If unset, no one can enter the console.
# ADMIN_EMAILS=you@example.com

# TEST-ONLY: extra non-.edu emails allowed to sign up while testing (Resend's
# sandbox only delivers to your Resend account email). Comma-separated.
# Remove this before launch; leave unset in production.
# TEST_EMAILS=you@example.com

# Secret used to sign the 30-day admin session cookie. Set a long random value
# in production (e.g. `openssl rand -hex 32`). If unset, a dev default is used —
# fine locally, but change it before deploying.
# SESSION_SECRET=replace-with-a-long-random-string
