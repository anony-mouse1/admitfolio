# Copy this file to ".env" and fill in the values. Next.js loads .env
# automatically, so you just run:  npm run dev

# ── Database (Supabase Postgres) ─────────────────────────
# From Supabase → Project Settings → Database → Connection string.
# DATABASE_URL: the *pooled* string (Supavisor, port 6543) — the
#   ?pgbouncer=true&connection_limit=1 params are required on serverless.
# DIRECT_URL: the *direct* string (port 5432) — used by `prisma migrate`.
# Use a separate dev Supabase project locally; never point local dev at prod.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Storage (essay PDFs) ────────────────────────
# From Supabase → Project Settings → API. The service-role key bypasses RLS —
# server-only, never expose it client-side (no NEXT_PUBLIC_ prefix, ever).
# Essays are stored in a *private* bucket named "essays".
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email (Resend) ───────────────────────────────────────
# Your Resend API key — get one free at https://resend.com/api-keys
# If unset, login codes are printed to the server console instead of emailed.
RESEND_API_KEY=re_your_key_here

# Who the email is "from".
# - Easiest: leave the sandbox sender (only delivers to your Resend account email).
# - To send to any .edu address, verify a domain in Resend, e.g.
#   FROM_EMAIL=Admitfolio <onboarding@yourdomain.com>
FROM_EMAIL=Admitfolio <onboarding@resend.dev>

# ── Admin & access ───────────────────────────────────────
# Where review-notification emails are sent (your inbox).
# ADMIN_EMAIL=you@example.com

# Who can sign into the admin review console (/admin). Verified by a 6-digit code
# — no shared password. Comma-separated. If unset, no one can enter the console.
# ADMIN_EMAILS=you@example.com

# Optional password login for the admin console, as an alternative to email
# codes. scrypt "salt:hash" hex — generate with:
#   node -e "const c=require('crypto'),s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync(process.argv[1],s,64).toString('hex'))" 'your-password'
# If unset, admins sign in with email codes only.
# ADMIN_PASSWORD_HASH=salt:hash

# TEST-ONLY: extra non-.edu emails allowed to sign up while testing (Resend's
# sandbox only delivers to your Resend account email). Comma-separated.
# Remove before launch; leave unset in production.
# TEST_EMAILS=you@example.com

# ── Sessions ─────────────────────────────────────────────
# Secret used to sign the admin session cookie and essay-upload tokens.
# REQUIRED in production (the app refuses to boot without it) — generate with
# `openssl rand -hex 32`.
# SESSION_SECRET=replace-with-a-long-random-string

# DEV-ONLY: fixed login code so local testing doesn't send real emails.
# The server accepts this code and skips email. REMOVE before deploying.
# DEV_LOGIN_CODE=000000
