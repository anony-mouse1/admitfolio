# Copy this file to ".env" and fill in the values. Next.js loads .env
# automatically, so you just run:  npm run dev

# ── Database ─────────────────────────────────────────────
# Local dev: SQLite file (zero setup). For production, point this at a hosted
# Postgres (Neon, Supabase, etc.) and set provider = "postgresql" in
# prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# ── Email (Resend) ───────────────────────────────────────
# Your Resend API key — get one free at https://resend.com/api-keys
# If unset, login codes are printed to the server console instead of emailed.
RESEND_API_KEY=re_your_key_here

# Who the email is "from".
# - Easiest: leave the sandbox sender (only delivers to your Resend account email).
# - To send to any .edu address, verify a domain in Resend, e.g.
#   FROM_EMAIL=Admitfolio <onboarding@yourdomain.com>
FROM_EMAIL=Admitfolio <onboarding@resend.dev>

# ── Admin & access ───────────────────────────────────────
# Where review-notification emails are sent (your inbox).
# ADMIN_EMAIL=you@example.com

# Who can sign into the admin review console (/admin). Verified by a 6-digit code
# — no shared password. Comma-separated. If unset, no one can enter the console.
# ADMIN_EMAILS=you@example.com

# TEST-ONLY: extra non-.edu emails allowed to sign up while testing (Resend's
# sandbox only delivers to your Resend account email). Comma-separated.
# Remove before launch; leave unset in production.
# TEST_EMAILS=you@example.com

# ── Sessions ─────────────────────────────────────────────
# Secret used to sign the 30-day admin session cookie. Set a long random value
# in production (e.g. `openssl rand -hex 32`).
# SESSION_SECRET=replace-with-a-long-random-string

# DEV-ONLY: fixed login code so local testing doesn't send real emails.
# The server accepts this code and skips email. REMOVE before deploying.
# DEV_LOGIN_CODE=000000
